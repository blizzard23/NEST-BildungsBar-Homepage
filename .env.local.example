# Supabase – Werte findest du im Supabase-Dashboard unter
# Project Settings -> API. Kopiere diese Datei zu ".env.local" und trage ein.
# In Vercel dieselben Variablen unter Settings -> Environment Variables setzen.

NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-public-key

# Optional: Empfänger-Adresse für die mailto-Fallback-Buttons (Standard: info@nest-bildungsbar.de)
# NEXT_PUBLIC_TERMIN_MAIL=info@nest-bildungsbar.de

# ---------------------------------------------------------------------
# SMTP – Mailversand über lima-city (Termin-, Kontakt- & Sonderanfragen)
# Werte aus deinem lima-city-Postfach (Webmail -> Einstellungen / Hilfe).
# ---------------------------------------------------------------------
SMTP_HOST=smtp.lima-city.de
SMTP_PORT=465
SMTP_SECURE=true              # true = SSL (Port 465), false = STARTTLS (Port 587)
SMTP_USER=postfach@deine-domain.de
SMTP_PASS=dein-postfach-passwort
MAIL_TO=info@nest-bildungsbar.de   # Wohin die Anfragen gehen
MAIL_FROM=postfach@deine-domain.de # Absender (muss zum Postfach passen)

